{
  "buildCommand": "bash build.sh",
  "outputDirectory": "build/web",
  "framework": "flutter",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "OPENROUTER_API_KEY": "@openrouter_api_key",
    "CLAUDE_API_KEY": "@claude_api_key",
    "GEMINI_API_KEY": "@gemini_api_key"
  }
}